{
  "title": "Sentinel — Latency Spikes",
  "uid": "sentinel-latency-spikes",
  "schemaVersion": 38,
  "time": { "from": "now-3h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Failure Probability (10m horizon)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 0.4 },
            { "color": "red", "value": 0.7 }
          ]
        }
      },
      "targets": [
        {
          "expr": "predictivex_failure_probability{model=\"latency-spikes\"}",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Failure Probability Over Time",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 6 },
      "targets": [
        {
          "expr": "predictivex_failure_probability{model=\"latency-spikes\"}",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Model State",
      "gridPos": { "x": 0, "y": 6, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "mappings": [
          { "type": "value", "options": { "0": { "text": "WAITING" }, "1": { "text": "TRAINING" }, "2": { "text": "INFERENCING" }, "3": { "text": "RETRAINING" }, "4": { "text": "ERROR" } } }
        ]
      },
      "targets": [
        { "expr": "predictivex_model_state{model=\"latency-spikes\"}", "legendFormat": "state" }
      ]
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Warmup Progress",
      "gridPos": { "x": 4, "y": 6, "w": 8, "h": 4 },
      "targets": [
        { "expr": "predictivex_model_warmup_progress{model=\"latency-spikes\"}", "legendFormat": "progress" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Consecutive Errors",
      "gridPos": { "x": 12, "y": 6, "w": 4, "h": 4 },
      "targets": [
        { "expr": "predictivex_model_consecutive_errors{model=\"latency-spikes\"}", "legendFormat": "errors" }
      ]
    }
  ]
}