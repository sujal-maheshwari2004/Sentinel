# =============================================================================
# Sentinel - Environment Variables
# Copy to .env and fill in values:  cp .env.example .env
# =============================================================================

# Weights & Biases (optional)
# W&B tracking activates automatically when this key is present.
# Leave commented out to use MLflow only.
# WANDB_API_KEY=your_key_here

# DVC remote storage (only needed if dvc.remote != local in sentinel.yaml)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# GCS
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Azure
# AZURE_STORAGE_CONNECTION_STRING=

# MLflow (optional override - also configurable in sentinel.yaml)
# MLFLOW_TRACKING_URI=http://mlflow:5000

# Sentinel log level (optional override - also configurable in sentinel.yaml)
# SENTINEL_LOG_LEVEL=info
